# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Load it with python-dotenv, or `set -a; source .env; set +a`.

# --- Required ---
# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# --- Recommended ---
# GitHub personal access token. Without it, search_github is throttled to 60 req/h.
# With a classic token (any scope, even no-scope works for public search), you get 5000 req/h.
GITHUB_TOKEN=

# --- Optional: agent tuning ---
# Override model. Default is claude-sonnet-4-6.
# For deep `--topic` runs you may want claude-opus-4-6 (~5x cost).
# AGENT_MODEL=claude-sonnet-4-6

# Max tool-use turns per session. Default 25. Bump for deep dives.
# AGENT_MAX_TURNS=25

# --- Optional: clustering ---
# Cosine similarity threshold for joining an existing cluster.
# Default is tuned for BAAI/bge-base-en-v1.5 (the default embedder), whose
# similarity scores run tighter than MiniLM's. Suggested ranges:
#   bge-base / bge-large : 0.80 - 0.85   (default 0.78 is on the loose side here)
#   all-MiniLM-L6-v2     : 0.75 - 0.80
# Tune empirically after ~30 findings: too many false merges → raise; too many
# distinct rows for the same idea → lower.
# CLUSTER_SIM_THRESHOLD=0.78

# --- Optional: embedding model ---
# Default: BAAI/bge-base-en-v1.5 (768-dim, ~440MB, top-tier MTEB scores).
# Alternatives:
#   all-MiniLM-L6-v2          — lighter (~80MB, 384-dim), good enough for most
#   BAAI/bge-large-en-v1.5    — bigger (~1.3GB, 1024-dim), marginal upgrade
#   mxbai-embed-large-v1      — state of the art, comparable to bge-large
# WARNING: switching after the DB has findings makes pre-switch and post-switch
# embeddings non-comparable. Switch on an empty DB or re-embed all rows.
# EMBED_PROVIDER=local
# EMBED_MODEL=BAAI/bge-base-en-v1.5
